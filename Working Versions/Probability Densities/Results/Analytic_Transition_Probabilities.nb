      " ", "150"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"kPlot", "=", 
    RowBox[{"Select", "[", 
     RowBox[{"kPlot", ",", 
      RowBox[{
       RowBox[{"MemberQ", "[", 
        RowBox[{"kList", ",", "#"}], "]"}], "&"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"idxForK", "=", 
    RowBox[{"AssociationThread", "[", 
     RowBox[{"kList", "->", 
      RowBox[{"Range", "[", 
       RowBox[{"Length", "[", "kList", "]"}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotCurves", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"densities", "[", 
       RowBox[{"[", 
        RowBox[{"idxForK", "[", "k", "]"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "kPlot"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"transitionPlot", "=", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{
      RowBox[{"Transpose", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Theta]Grid", ",", "#"}], "}"}], "&"}], "/@", 
         "plotCurves"}], ")"}]}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<\[Theta]\>\"", ",", "\"\<p_k(\[Theta])\>\""}], "}"}]}], 
      ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\"\<k = \>\"", ",", "#"}], "}"}], "]"}], "&"}], "/@", 
         "kPlot"}], ")"}]}], ",", 
      RowBox[{"ImageSize", "->", "Large"}], ",", 
      RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}]}], "]"}]}], ";"}], 
