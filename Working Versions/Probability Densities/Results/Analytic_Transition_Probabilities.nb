Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"$HistoryLength", "=", "0"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"2", "^", "6"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"a", "=", "0.1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p", "=", "1500"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"kList", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"2", ",", "150"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"N\[Theta]", "=", "1000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Theta]Grid", "=", 
    RowBox[{"N", "@", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"0", ",", 
       RowBox[{"Pi", "/", "2"}], ",", "N\[Theta]"}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"exportDir", "=", 
    RowBox[{
     RowBox[{"NotebookDirectory", "[", "]"}], "/.", " ", 
     RowBox[{"$Failed", "->", 
      RowBox[{"Directory", "[", "]"}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{
      RowBox[{"\[Theta]_", "?", "NumericQ"}], ",", "n_Integer", ",", 
      RowBox[{"a_", "?", "NumericQ"}], ",", 
      RowBox[{"k_", "?", "NumericQ"}], ",", "p_Integer"}], "]"}], ":=", 
    RowBox[{"2", " ", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "n"}], "-", "3"}], ")"}]}], " ", 
     RowBox[{"Cos", "[", "\[Theta]", "]"}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "m"}], "+", "n", "-", "1"}], ")"}], " ", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"m", "+", "n", "-", "2"}], ",", 
          RowBox[{"n", "-", "2"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"JacobiP", "[", 
            RowBox[{"m", ",", 
             RowBox[{"n", "-", "2"}], ",", "0", ",", 
             RowBox[{"Cos", "[", 
              RowBox[{"2", " ", "a"}], "]"}]}], "]"}], "/", 
           RowBox[{"JacobiP", "[", 
            RowBox[{"m", ",", 
             RowBox[{"n", "-", "2"}], ",", "0", ",", "1"}], "]"}]}], ")"}], 
         "^", "k"}], "*", 
        RowBox[{"JacobiP", "[", 
         RowBox[{"m", ",", 
          RowBox[{"n", "-", "2"}], ",", "0", ",", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", "0", ",", "p"}], "}"}]}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"densities", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"k", "=", 
          RowBox[{"kList", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"f", "[", 
             RowBox[{"#", ",", "n", ",", "a", ",", "k", ",", "p"}], "]"}], 
            ")"}], "&"}], "/@", "\[Theta]Grid"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "kList", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", "\"\<Preparing CSV export...\>\"", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"exportMatrix", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"kList", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "}"}], ",", 
        RowBox[{"densities", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "kList", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"header", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", "\"\<k\>\"", "}"}], ",", "\[Theta]Grid"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"csvTable", "=", 
    RowBox[{"Prepend", "[", 
     RowBox[{"exportMatrix", ",", "header"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"kMin", "=", 
   RowBox[{"Min", "[", "kList", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"kMax", "=", 
    RowBox[{"Max", "[", "kList", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"aStr", "=", 
    RowBox[{"StringReplace", "[", 
     RowBox[{
      RowBox[{"ToString", "@", 
       RowBox[{"NumberForm", "[", 
        RowBox[{"a", ",", 
         RowBox[{"{", 
          RowBox[{"Infinity", ",", "3"}], "}"}], ",", 
         RowBox[{"NumberPadding", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}]}], "]"}]}], ",", 
      RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"outBase", "=", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{"exportDir", ",", 
       RowBox[{"\"\<analytic_CPn_density_\>\"", "<>", "\"\<n\>\"", "<>", 
        RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<_a\>\"", "<>", "aStr",
         "<>", "\"\<_p\>\"", "<>", 
        RowBox[{"ToString", "[", "p", "]"}], "<>", "\"\<_k\>\"", "<>", 
        RowBox[{"ToString", "[", "kMin", "]"}], "<>", "\"\<-\>\"", "<>", 
        RowBox[{"ToString", "[", "kMax", "]"}]}]}], "}"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"outFile", "=", 
    RowBox[{"outBase", "<>", "\"\<.csv\>\""}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{"outFile", ",", "csvTable", ",", "\"\<CSV\>\""}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<Exported single CSV:\>\"", "]"}], ";"}], "\n", 
